# Copy to backend/.env for local development. Never commit .env.
# Every variable is optional unless marked required — defaults suit local dev.

# --- LLM backend ---
# "ollama" (local inference) or "anthropic" (hosted)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_MODEL=claude-sonnet-5
# Required when LLM_PROVIDER=anthropic — startup fails fast without it
#ANTHROPIC_API_KEY=sk-ant-...
LLM_TEMPERATURE=0.0

# --- API ---
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# --- Pipeline ---
# How many Parser attempts before the Critic escalates to a human (1-10)
MAX_PARSE_ATTEMPTS=3
# Override data locations if needed (defaults live under backend/app/)
#RULES_PATH=/path/to/compliance_rules.yaml
#PATIENTS_PATH=/path/to/patients.json

# --- Observability ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
