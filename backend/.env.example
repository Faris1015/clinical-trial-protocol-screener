# Copy to backend/.env for local development. Never commit .env.
# Every variable is optional unless marked required — defaults suit local dev.

# --- LLM backend ---
# "ollama" (local inference) or "anthropic" (hosted)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_MODEL=claude-sonnet-5
# Required when LLM_PROVIDER=anthropic — startup fails fast without it
#ANTHROPIC_API_KEY=sk-ant-...
LLM_TEMPERATURE=0.0

# --- API ---
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# --- API hardening ---
# Max upload size in bytes (default 25 MiB). Oversized uploads are rejected 413.
MAX_UPLOAD_BYTES=26214400
# Content-type allowlist for uploads (comma-separated). Generic/empty types fall
# back to a .pdf/.md/.txt filename-extension check.
UPLOAD_CONTENT_TYPES=application/pdf,text/markdown,text/plain
# IP-keyed rate limits ("N/second|minute|hour"). Strict on create, generous on reads.
RATE_LIMIT_CREATE=10/minute
RATE_LIMIT_READ=120/minute
# Set false to disable rate limiting entirely (the test suite does this).
RATE_LIMIT_ENABLED=true
# Concurrent in-flight screenings per instance; excess requests get 429 + Retry-After.
MAX_CONCURRENT_SCREENINGS=4
CONCURRENCY_RETRY_AFTER_SECONDS=5
# SSE heartbeat cadence and idle-reap timeout (seconds).
SSE_HEARTBEAT_SECONDS=15
SSE_IDLE_TIMEOUT_SECONDS=120

# --- Pipeline ---
# How many Parser attempts before the Critic escalates to a human (1-10)
MAX_PARSE_ATTEMPTS=3
# Override data locations if needed (defaults live under backend/app/)
#RULES_PATH=/path/to/compliance_rules.yaml
#PATIENTS_PATH=/path/to/patients.json

# --- Persistence ---
# Where LangGraph execution state + screening metadata live.
#   memory   = process-local, lost on restart (tests only)
#   sqlite   = durable single-node default
#   postgres = multi-replica production (install the extra: pip install -e ".[postgres]")
CHECKPOINT_BACKEND=sqlite
# sqlite file (both the checkpointer and the screening store share it)
#SQLITE_PATH=/path/to/screenings.sqlite
# Required when CHECKPOINT_BACKEND=postgres — startup fails fast without it
#POSTGRES_DSN=postgresql://user:pass@localhost:5432/screener

# --- Observability ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# "console" = human-readable, colorized (dev); "json" = one object per line (prod)
LOG_FORMAT=console
